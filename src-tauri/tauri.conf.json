{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "What's on My Desk",
  "version": "0.1.0",
  "identifier": "com.whatsonmydesk.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "What’s on My Desk?",
        "width": 1120,
        "height": 760,
        "minWidth": 620,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.ico"]
  }
}
