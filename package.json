{
  "name": "whats-on-my-desk-web",
  "private": true,
  "version": "0.1.0-alpha.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build --configLoader runner",
    "agent:dev": "cargo run --manifest-path src-tauri/Cargo.toml",
    "build:extension": "powershell -ExecutionPolicy Bypass -File scripts/build-extension.ps1",
    "build:agent": "powershell -ExecutionPolicy Bypass -File scripts/build-desktop.ps1",
    "preview": "vite preview",
    "pages:deploy": "npx wrangler pages deploy dist --project-name whats-on-my-desk --branch main"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
